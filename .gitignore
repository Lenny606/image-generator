# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   often managed by the project's contributors or the build server.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should ideally have a separate
#   gitignore file, but many people prefer to keep it in the main one.
# Pipfile.lock

# poetry
#   Poetry uses pyproject.toml and poetry.lock to manage dependencies.
#   The virtual environment is usually stored outside the project, but if it's
#   inside (e.g. .venv), it should be ignored.
.venv/
poetry.lock

# pdm
#   PDM stores configuration in .pdm.toml and project-local packages in __pypackages__/
.pdm.toml
__pypackages__/

